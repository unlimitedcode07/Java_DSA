136. Single Number

js solution

/**
 * @param {number[]} nums
 * @return {number}
 */
var singleNumber = function(nums) {
    return nums.reduce((ans,el)=>ans^el);
};



java solution

class Solution {
    public int singleNumber(int[] nums) {
        int ans = 0;
        for(int el:nums){
          ans = ans^el;
        }
        return ans;
    }
}