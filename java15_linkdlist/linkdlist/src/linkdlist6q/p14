class Solution {



    deleteNode(head, key) {
        let temp1 = new Node(-1);
        let temp = temp1;
        temp.next = head;
        temp = head;


        while(temp.next != head){
            if(temp.data == key){
                temp.data = temp.next.data;
                if(temp.next.next == head) temp.next = head;
                else temp.next  = temp.next.next;
                break;
            }
            if(temp.next.data == key && temp.next.next == head){
               temp.next = head;
                break;
            }


            temp = temp.next;
        }
        return temp1.next



    }
}

